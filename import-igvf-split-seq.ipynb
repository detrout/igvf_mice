  {
   "cell_type": "markdown",
   "id": "historic-stand",
   "metadata": {},
   "source": [
    "# Information from Samples into experiment\n",
    "\n",
    "- Total barcoded nuclei (Samples into experiment)\n",
    "\n",
    "Is this FixedTissue, ParseFixedSample, FixedBiosample?\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "turkish-lexington",
   "metadata": {
    "scrolled": true
   },
   "outputs": [],
   "source": [
    "# known sheets containing fixed sample data\n",
    "fixed_sheets = [\n",
    "    # (book name, sheet name, header start line)\n",
    "    (founder_sheet_name, \"Founder Samples into experiment\", 0),\n",
    "    (bridge_sheet_name, \"Bridge samples into experiment\", 0),\n",
    "    (f1_sheet_name, \"F1 Samples into experiment\", 1),\n",
    "    # According to Liz this sheet isn't ready yet.\n",
    "    (lizs_sheet_name, \"CC Samples into experiment\", 1),\n",
    "]\n",
    "\n",
    "\n",
    "# According to liz: 10 and 11 were originally defined for gonads of both females and males. \n",
    "# 10 was originally ovaries or testes, and 11 was oviducts or epididymides, since we \n",
    "# collected gonads in separate tubes. However, when we do the experiment, the gonads \n",
    "# from an individual samples are pooled, which led to using 26 to indicate \n",
    "# pooled ovaries/oviducts from 1 female mouse and 25 to indicate pooled testes/epididymides from\n",
    "# 1 male mouse. We are still collecting gonads in separate tubes, so females are still 10 and 11\n",
    "# ovaries/oviducts and pooled to make 26. However, the males changed slightly — for the F1s and \n",
    "# CCs, we are collecting left and right testis and left and right epididymis separately, so\n",
    "# no more 10/11 for males, but 27, 28, 29, 30 (left testis, right testis, left epididymis, right \n",
    "# epididymis). We are pooling the left testis and left epididymis rather than both sides for the \n",
    "# final plate, so 27 & 29 are now pooled to make 25.        \n",
    "\n",
    "def validate_sex_specific_tissue(tissue_id, sex=None):    \n",
    "    tissue = parse_mouse_tissue(tissue_id)\n",
    "    \n",
    "    if sex is None:\n",
    "        sex = models.SexEnum(tissue.mouse_sex)\n",
    "    elif isinstance(sex, str):\n",
    "        sex = models.SexEnum(sex)\n",
    "\n",
    "    sex_specific_tissues = {\n",
    "        # left/right testis, left/right epididymis\n",
    "        models.SexEnum.MALE: [\"10\", \"11\", \"27\", \"28\", \"29\", \"30\"],\n",
    "        # ovary, ovaduct\n",
    "        models.SexEnum.FEMALE: [\"10\", \"11\", \"26\"],\n",
    "    }\n",
    "\n",
    "    if tissue.tissue_id not in sex_specific_tissues[sex]:\n",
    "        print(\n",
    "            \"Invalid tissue ID for {} mouse {}. allowed tissues {}\".format(\n",
    "                sex.name.lower(),\n",
    "                tissue_id,\n",
    "                sex_specific_tissues[sex]))\n",
    "\n",
    "\n",
    "def validate_pooled_from(tissue_id, pooled_from):\n",
    "    \"\"\"Testis and ovaries have different tissue ids\"\"\"\n",
    "    tissue = parse_mouse_tissue(tissue_id)\n",
    "    \n",
    "    allowed_child_tissues = {\n",
    "        \"25\": [\"10\", \"11\",\"27\", \"29\",],\n",
    "        \"26\": [\"10\", \"11\",],\n",
    "        #\"29\": [],\n",
    "    }\n",
    "    for pooled_id in pooled_from:\n",
    "        pooled_tissue = parse_mouse_tissue(pooled_id)\n",
    "        \n",
    "        # equality always passes\n",
    "        if tissue == pooled_tissue:\n",
    "            continue\n",
    "        \n",
    "        if tissue.mouse_id != pooled_tissue.mouse_id:\n",
    "            raise ValueError(\"Mouse dissection id does not match in {} {}\".format(tissue_id, pooled_id))\n",
    "        \n",
    "        if tissue.mouse_strain != pooled_tissue.mouse_strain:\n",
    "            raise ValueError(\"Mouse strain does not match in {} {}\".format(tissue_id, pooled_id))\n",
    "            \n",
    "        if tissue.mouse_age != pooled_tissue.mouse_age:\n",
    "            raise ValueError(\"Mouse age value does not match in {} {}\".format(tissue_id, pooled_id))\n",
    "\n",
    "        if tissue.mouse_sex != pooled_tissue.mouse_sex:\n",
    "            raise ValueError(\"Mouse sex value does not match in {} {}\".format(tissue_id, pooled_id))\n",
    "\n",
    "        elif pooled_tissue.tissue_id not in allowed_child_tissues[tissue.tissue_id]:\n",
    "            print(\"Mouse tissue_id {} includes an unexpeced pooled tissue {}\".format(\n",
    "                tissue_id, pooled_id))\n",
    "\n",
    "def get_box_id(row):\n",
    "    for label_name in [\"IGVF Fixation BOX\", \"IGVF Sample BOX\", \"Box ID\"]:\n",
    "        if label_name in row.index:\n",
    "            return row[label_name]\n",
    "\n",
    "\n",
    "def get_nuclei_per_ul_before_fixation(row):\n",
    "    if pandas.notnull(row.get(\"Count 1\")):\n",
    "        return None\n",
    "    \n",
    "    for name in [\"Nuclei/mL (x10^6)\"]:\n",
    "        if name in row.index:\n",
    "            value = float_or_none(row[name])\n",
    "            if value is None:\n",
    "                return None\n",
    "            else:\n",
    "                return value * 1000\n",
    "\n",
    "    print(\"Warning unable to find nuclei/ml in {}\".format(row))\n",
    "\n",
    "def get_nuclei_per_ul_after_fixation(row):\n",
    "    if pandas.notnull(row.get(\"Count 1.1\")):\n",
    "        return None\n",
    "    \n",
    "    for name in [\"Nuclei/mL (x10^6).1\"]:\n",
    "        if name in row.index:\n",
    "            return float(row[name]) * 1000\n",
    "\n",
    "    print(\"Warning unable to find nuclei/ml in {}\".format(row))\n",
    "\n",
    "def get_nuclei_into_fixation(row):\n",
    "    for name in [\"Nuclei into fixation (x10^6)\", \"Nuclei into PARSE (x10^6)\"]:\n",
    "        if name in row.index:\n",
    "            return row[name]\n",
    "\n",
    "def get_input_to_share(row):\n",
    "    share_input = row.get(\"uL Input to SHARE\")\n",
    "    if share_input is None:\n",
    "        return None\n",
    "    else:\n",
    "        return float_or_none(share_input)\n",
    "\n",
    "def load_samples_into_experiment():\n",
    "    book_cache = {}\n",
    "    \n",
    "    one_based = 1\n",
    "    header_lines = 2\n",
    "    fixed_samples = []\n",
    "\n",
    "    for book_name, sheet_name, header in fixed_sheets:\n",
    "        book = book_cache.get(book_name, pandas.ExcelFile(book_name))\n",
    "\n",
    "        samples = book.parse(sheet_name=sheet_name, header=header, index_col=None).dropna(how=\"all\")\n",
    "        samples.rename({\n",
    "            \"Technician / Layering technician\": \"Fixation Tech.\",\n",
    "            \"Technician\": \"Fixation Tech.\",\n",
    "            \"Fixed sample counting technician\": \"Fixed Count Tech.\",\n",
    "            \"Weight (mg)\": \"weight (mg)\",   # Used on CC Samples into experiment\n",
    "            \"RSB (mL)\": \"Volume RSB (mL)\",  # Used on CC Samples into experiment\n",
    "            \"Total Nuclei (x10^6)\": \"Total nuclei (x10^6)\",  # Used on CC Samples into experiment\n",
    "            \"Total Fixed Nuclei (x10^6)\": \"Total fixed nuclei (x10^6)\",   # Used on CC Samples into experiment\n",
    "        }, axis=1, inplace=True)\n",
    "        if \"Input to Parse (mL)\" not in samples.columns and \"Input to Fixation (uL)\" in samples.columns:\n",
    "            samples[\"Input to Parse (mL)\"] = samples[\"Input to Fixation (uL)\"].apply(lambda x: float_or_nan(x) / 1000)\n",
    "        #print(samples.columns)\n",
    "        print(\"Loading sheet {}\".format(sheet_name))\n",
    "        #print(samples.head())\n",
    "    \n",
    "        assert \"Mouse_Tissue ID\" in samples.columns, \"Expected column Mouse_Tissue ID is missing.\"\n",
    "        failed = False\n",
    "        for i, row in samples.iterrows():\n",
    "            line_no = i + one_based + header_lines\n",
    "\n",
    "            box_name = get_box_id(row)\n",
    "            if pandas.isnull(box_name ):\n",
    "                continue\n",
    "\n",
    "            if isinstance(box_name, str):\n",
    "                box_name = box_name.strip()\n",
    "\n",
    "            if box_name in [\"IGVF_FIX_001\", \"IGVF_FIX_002\"]:\n",
    "                continue\n",
    "\n",
    "            if pandas.isnull(row[\"Mouse_Tissue ID\"]):\n",
    "                continue\n",
    "\n",
    "            if pandas.isnull(row[\"Tissue\"]):\n",
    "                continue\n",
    "            \n",
    "            if pandas.isnull(row[\"Total nuclei (x10^6)\"]):\n",
    "                #print(f\"Skipped {row['Mouse_Tissue ID']} null total nuclei {row['Total nuclei (x10^6)']}\")\n",
    "                #continue\n",
    "                row[\"Total nuclei (x10^6)\"] = numpy.nan\n",
    "            elif row[\"Total nuclei (x10^6)\"] in (\"#DIV/0!\", \"#VALUE!\"):\n",
    "                row[\"Total nuclei (x10^6)\"] = numpy.nan\n",
    "\n",
    "            tissue_fields = parse_mouse_tissue(row[\"Mouse_Tissue ID\"])\n",
    "            tissue_id = join_mouse_tissue(tissue_fields)\n",
    "            pooled_from = row.get(\"pooled_from\")\n",
    "\n",
    "            if pandas.isnull(tissue_id):\n",
    "                continue\n",
    "\n",
    "            #validate_sex_specific_tissue(tissue_id)\n",
    "\n",
    "            if pandas.isnull(pooled_from):\n",
    "                pooled_from = [tissue_id]\n",
    "            else:\n",
    "                normalized_pool = []\n",
    "                for pooled_id in pooled_from.split(\",\"):\n",
    "                    normalized_pool.append(join_mouse_tissue(parse_mouse_tissue(pooled_id.strip())))\n",
    "                pooled_from = normalized_pool\n",
    "\n",
    "            validate_pooled_from(tissue_id, pooled_from)\n",
    "\n",
    "            try:\n",
    "                tissue = models.Tissue.objects.get(pk=pooled_from[0])\n",
    "            except models.Tissue.DoesNotExist as e:\n",
    "                print(\"Unable to find tissue id {} in tissue databsae\".format(pooled_from[0]))\n",
    "                continue\n",
    "            \n",
    "            tissue_term = tissue.ontology_term.first()\n",
    "            protocol = protocol_by_ontology[tissue_term.curie]\n",
    "            assert protocol is not None, \"We need another protocol added for {}\".format(tissue_term)\n",
    "            cellular_component = cellular_component_by_protocol[protocol]\n",
    "\n",
    "            weight = positive_int_or_none(row[\"weight (mg)\"])\n",
    "            \n",
    "            fixation_date = row[\"Fixation date\"]\n",
    "            notes = row[\"Notes\"]\n",
    "\n",
    "            sample_id = normalize_strain(row[\"Sample ID\"]) if not pandas.isnull(row[\"Sample ID\"]) else None\n",
    "            if not (pandas.isnull(sample_id) or pandas.isnull(tissue_id)):\n",
    "                if tissue_id != sample_id:\n",
    "                    print(f\"If defined, {tissue_id} should equal {sample_id} line {line_no}\")\n",
    "                    failed = True\n",
    "\n",
    "            cap_label = row[\"Cap label\"]\n",
    "            if not validate_splitseq_cap_label(cap_label, sample_id):\n",
    "                failed = True\n",
    "\n",
    "            well_id = row[\"wells in Barcoding plate\"]\n",
    "            \n",
    "            fixed_samples.append({\n",
    "                \"tissue_id\": tissue_id,\n",
    "                \"tube_label\": cap_label,\n",
    "                \"fixation_name\": box_name,\n",
    "                \"fixation_date\": row[\"Fixation date\"],\n",
    "                \"pooled_from\": pooled_from,\n",
    "                \"weight\": weight,\n",
    "                \"isolation_technician\": row.get(\"Isolation Tech.\", None),\n",
    "                \"fixation_technician\": row[\"Fixation Tech.\"],\n",
    "                \"fixed_count_technician\": row[\"Fixed Count Tech.\"],\n",
    "                \"volume_ul\": row[\"Volume RSB (mL)\"] * 1000,\n",
    "                \"before_count1\": row.get(\"Count 1\"),\n",
    "                \"before_count2\": row.get(\"Count 2\"),\n",
    "                \"before_df1\": row.get(\"DF1\"),\n",
    "                \"before_df2\": row.get(\"DF2\"),\n",
    "                \"nuclei_per_ul_before_fixation\": get_nuclei_per_ul_before_fixation(row),\n",
    "                \"starting_nuclei\": row[\"Total nuclei (x10^6)\"],\n",
    "                \"nuclei_into_fixation\": get_nuclei_into_fixation(row),\n",
    "                \"fixed_nuclei\": row[\"Total fixed nuclei (x10^6)\"],\n",
    "                \"parse_input_ul\": float(row.get(\"Input to Parse (mL)\")) * 1000,\n",
    "                \"share_input_ul\": get_input_to_share(row),\n",
    "                \n",
    "                \"after_count1\": row.get(\"Count 1.1\"),\n",
    "                \"after_count2\": row.get(\"Count 2.1\"),\n",
    "                \"after_df1\": row.get(\"DF\", row.get(\"DF1.1\")),\n",
    "                \"after_df2\": row.get(\"DF2.1\"),\n",
    "                \"nuclei_per_ul_after_fixation\": get_nuclei_per_ul_after_fixation(row),\n",
    "                \n",
    "                \"aliquots_made\": row[\"# aliquots\"],\n",
    "                \"aliquot_volume_ul\": row[\"uL per aliquot\"],\n",
    "                \"comments\": row[\"Notes\"],\n",
    "                \"sheet_name\": sheet_name,\n",
    "                \"line_no\": line_no,\n",
    "                \n",
    "                \"cellular_component\": cellular_component,\n",
    "                \"protocol\": [protocol],\n",
    "            })\n",
    "\n",
    "    df = pandas.DataFrame(fixed_samples)\n",
    "    duplicated = df.tissue_id.duplicated()\n",
    "    print(\"Current {} duplicated entries\".format(duplicated.sum()))\n",
    "    df = df.drop_duplicates(subset=[\"tissue_id\"])\n",
    "    return df\n",
    "\n",
    "fixed_samples = load_samples_into_experiment()\n",
    "fixed_samples"
   ]
  },
