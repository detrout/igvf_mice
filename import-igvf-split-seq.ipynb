    "def get_current_or_previous(row, previous, term):\n",
    "    if pandas.notnull(row[term]):\n",
    "        return row[term]\n",
    "    elif previous is not None and pandas.notnull(previous[term]):\n",
    "        row[term] = previous[term]\n",
    "        return previous[term]\n",
    "\n",
    "def load_ont_splitseq_sequencing():\n",
    "    nanopore_samples = {}\n",
    "    sheet = pandas.read_excel(lizs_sheet_name, sheet_name=\"ONT Sequencing\", skiprows=1)\n",
    "    sheet[\"ONT Instrument\"] = sheet[\"ONT Instrument\"].apply(instrument_name_to_platform_id)\n",
    "    sheet[\"subpool\"] = sheet.apply(get_ont_splitseq_subpool_name, axis=1)\n",
    "\n",
    "    for ont_plate in find_ont_splitseq_plate_boundaries(sheet):\n",
    "        prev_row = None\n",
    "        for i, row in sheet[ont_plate.start:ont_plate.end].iterrows():        \n",
    "            tube_id = get_current_or_previous(row, prev_row, \"ONT Library Replicate ID\")\n",
    "            sample_id = get_current_or_previous(row, prev_row, \"Sample ID\")\n",
    "            if pandas.isnull(tube_id):\n",
    "                continue\n",
    "            else:\n",
    "                nanopore_samples[sample_id] = {\n",
    "                    \"plate\": normalize_ont_splitseq_plate_name(ont_plate.name),\n",
    "                    \"subpool\": row[\"subpool\"],\n",
    "                    \"name\": tube_id,\n",
    "                    \"sample_id\": row[\"Sample ID\"],\n",
    "                    # nucleic acid extraction attributes\n",
    "                    \"cdna_build_date\": get_current_or_previous(row, prev_row, \"cDNA Build Date\"),\n",
    "                    \"cdna_volume_ul\": get_current_or_previous(row, prev_row, \"cDNA Volume (uL)\"),\n",
    "                    \"cdna_ng_per_ul\": get_current_or_previous(row, prev_row, \"[cDNA] (ng/uL)\"),\n",
    "                    \"average_length\": get_current_or_previous(row, prev_row, \"Average Length (bp)\"),\n",
    "                    \"technician\": \",\".join(ont_plate.technicians),\n",
    "                    \"passed_qc\": True, # Otherwise it wouldn't be in this sheet.\n",
    "                    # nanopore library attribtes\n",
    "                    \"library_build_date\": get_current_or_previous(row, prev_row, \"Library Build Date\"),\n",
    "                    \"library_volume_ul\": get_current_or_previous(row, prev_row, \"Lib. Vol. (uL)\"),\n",
    "                    \"library_input_ng_per_ul\": get_current_or_previous(row, prev_row, \"[Library] (ng/uL)\"),\n",
    "                    # sequencing run attributes\n",
    "                    \"sequencing_run_date\": get_current_or_previous(row, prev_row, \"Sequencing Date\"),\n",
    "                    \"sequencing_run_platform\": get_current_or_previous(row, prev_row, \"ONT Instrument\"),\n",
    "                    \"flowcell_kit\": get_current_or_previous(row, prev_row, \"Kit\"),\n",
    "                    \"flowcell_type\": get_current_or_previous(row, prev_row, \"Flow Cell Type\"),\n",
    "                    \"flowcell_id\": get_current_or_previous(row, prev_row, \"Flow Cell ID\"),\n",
    "                    \"sequencing_software\": get_current_or_previous(row, prev_row, \"Basecaller\"),\n",
    "                    \"comments\": get_current_or_previous(row, prev_row, \"Notes\"),\n",
    "                }\n",
    "\n",
    "                try:\n",
    "                    subpool = models.Subpool.objects.get(pk=row[\"subpool\"])\n",
    "                except models.Subpool.DoesNotExist as e:\n",
    "                    print(\"Unable to find subpool {}\".format(row[\"subpool\"]))\n",
    "                    raise e\n",
    "            prev_row = row\n",
    "\n",
    "    return pandas.DataFrame(nanopore_samples.values())\n",
    "\n",
    "ont_sequencing = load_ont_splitseq_sequencing()\n",
    "ont_sequencing\n"
   ]
  },
