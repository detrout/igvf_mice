    "\n",
    "def validate_mouse_genotype_and_strain(genotype, strain):\n",
    "    if genotype.upper() == \"TREM2R47HNSS_HO\":\n",
    "        expected_genotype = \"TREM2\"\n",
    "    else:\n",
    "        expected_genotype = genotype\n",
    "        \n",
    "    if expected_genotype != strain:\n",
    "        raise ValueError(\"Expected genotype {} does not match detected strain {}\".format(\n",
    "            expected_genotype, strain))\n",
    "    \n",
    "def load_tissue_sheets(mice):\n",
    "    tissues = []\n",
    "    for book_url, tissue_sheet in sample_sheets:\n",
    "        tissue = pandas.read_excel(\n",
    "            book_url, \n",
    "            sheet_name=tissue_sheet,\n",
    "            header=0,\n",
    "        ).dropna(axis=0, how=\"all\")\n",
    "\n",
    "        if \"tube+tissue wight (g)\" in tissue.columns:\n",
    "            print(f\"{tissue_sheet} has typoed wight column, renaming to weight\")\n",
    "            tissue = tissue.rename(columns={\n",
    "                \"tube+tissue wight (g)\": \"tube+tissue weight (g)\"\n",
    "            })\n",
    "               \n",
    "        tissue = tissue.rename(columns={\n",
    "            \"Approx. sac time\": \"Dissection start\",\n",
    "            \"Dissection Start\": \"Dissection start\",\n",
    "            \"Dissection End\": \"Dissection end\",\n",
    "            \"Blood volume (mL)\": \"volume (mL)\",\n",
    "            \"# PBMCs before fixation (x 10^6)\": \"cells before fixation (x 10^6)\",\n",
    "            \"-80C box\": \"IGVF Sample BOX\",\n",
    "        })\n",
    "\n",
    "        for time_name in [\"Dissection start\", \"Dissection end\"]:\n",
    "            if time_name in tissue.columns:\n",
    "                tissue[time_name] = list(normalize_mice_date(tissue[\"Dissection date\"], tissue[time_name]))\n",
    "            #else:\n",
    "            #    tissue[\"Dissection end\"] = [None] * tissue.shape[0]\n",
    "            \n",
    "        print(tissue_sheet, tissue.shape)\n",
    "        tissues.append(tissue)\n",
    "\n",
    "    combined = pandas.concat(tissues)\n",
    "    # force column names to be lowercase\n",
    "    combined.columns = [x.lower() for x in combined.columns]\n",
    "    has_tissue_id = pandas.notnull(combined[\"mouse_tissue id\"])\n",
    "    has_tissue = pandas.notnull(combined[\"tissue\"])\n",
    "    has_box = combined[\"igvf sample box\"].apply(lambda x: x != \"DNA Extraction Optimization\")\n",
    "    has_genotype = pandas.notnull(combined[\"genotype\"])\n",
    "    combined = combined[has_tissue_id & has_tissue & has_box & has_genotype]\n",
    "    print(\"Total after filtering\", combined.shape)\n",
    "    \n",
    "    combined[\"mouse_tissue id\"] = combined[\"mouse_tissue id\"].apply(normalize_strain)\n",
    "\n",
    "    mouse_tissue_name_fields = combined[\"mouse_tissue id\"].apply(parse_mouse_tissue)\n",
    "    #for row in mouse_tissue_name_fields:\n",
    "    #    if not row.mouse_strain in mouse_strain_code_to_name:\n",
    "    #        raise ValueError(f\"tissue strain field in {row} not recognized\")\n",
    "\n",
    "    combined[\"mouse name\"] = mouse_tissue_name_fields.apply(join_mouse_name)\n",
    "    combined[\"tissue_name\"] = combined[\"tissue\"].apply(lambda tissue: [x[1] for x in tissue_dissection_to_ontology_map[tissue]])\n",
    "    combined[\"tissue_id\"] = combined[\"tissue\"].apply(lambda tissue: [x[0] for x in tissue_dissection_to_ontology_map[tissue]])\n",
    "\n",
    "    mice = mice.set_index(\"Mouse Name\")\n",
    "    mice_name = set(mice.index)\n",
    "    combined_mice = set(combined[\"mouse name\"])\n",
    "    print(\"Dropping\", sorted(combined_mice.difference(mice_name)))\n",
    "    combined = combined[combined[\"mouse name\"].isin(mice_name)]\n",
    "    print(\"Total after filtering for mice\", combined.shape)\n",
    "\n",
    "    for i, row in combined.iterrows():\n",
    "        # this is the \"label swap\" on spreadsheet rows 602-605.\n",
    "        if row[\"mouse name\"] == \"092_CASTJ_10F\":\n",
    "            row[\"genotype\"] = \"CASTJ\"\n",
    "            #combined.loc[i, \"Genotype\"] = \"CASTJ\"\n",
    "        # this is the other half the swap on spreadsheet rows 1522-1525\n",
    "        elif row[\"mouse name\"] == \"046_NZOJ_10F\":\n",
    "            row[\"genotype\"] = 'NZOJ'\n",
    "            #combined.loc[i, \"Genotype\"] = 'NZOJ'\n",
    "            \n",
    "        validate_mouse_genotype_and_strain(row[\"genotype\"], mice.loc[row[\"mouse name\"], \"Mouse code\"])\n",
    "\n",
    "    assert \"tube+tissue wight (g)\" not in combined.columns\n",
    "    return combined\n",
    "\n",
    "tissue_sheets = load_tissue_sheets(mice)\n",
    "tissue_sheets.head()"
   ]
  },
