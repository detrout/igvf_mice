    "def load_spreadsheet_mice():\n",
    "    mice = pandas.read_excel(\n",
    "        lizs_sheet_name, \n",
    "        sheet_name=\"mice\", \n",
    "        converters={\n",
    "            #\"Dissection ID\": int,\n",
    "            #\"RMS number\": int_or_none,\n",
    "            \"Sex\": models.get_sex_code,\n",
    "            \"Strain\": normalize_mice_strain_name,\n",
    "        }\n",
    "    )\n",
    "    \n",
    "    print(\"Loaded\", mice.shape[0])\n",
    "    has_dissection = pandas.notnull(mice[\"Dissection ID\"])\n",
    "    has_name = pandas.notnull(mice[\"Mouse Name\"])\n",
    "    has_strain = pandas.notnull(mice[\"Strain\"])\n",
    "    has_sex = pandas.notnull(mice[\"Sex\"])\n",
    "    mice = mice[has_name & has_dissection & has_strain & has_sex]\n",
    "    print(\"Filtered null rows\", mice.shape[0])\n",
    "    mice[\"Mouse Name\"] = mice[\"Mouse Name\"].apply(normalize_mice_name)\n",
    "    mouse_name_fields = mice[\"Mouse Name\"].apply(parse_mouse_name)\n",
    "    mice[\"Mouse code\"] = [x[1] for x in mouse_name_fields]\n",
    "    for field_name in [\"Dissection start time\", \"Dissection finish time\"]:\n",
    "        mice[field_name] = list(normalize_mice_date(mice[\"Dissection Date\"], mice[field_name]))\n",
    "    mice[\"estrus_cycle\"] = mice[\"Estrus cycle stage\"].apply(models.get_estrus_cycle_code)\n",
    "    mice[\"Strain code\"] = mice[\"Strain\"].apply(strain_name_to_code.get)\n",
    "    mice = mice.drop(columns=[\"Dissection Date\", \"Estrus cycle stage\"])\n",
    "    \n",
    "    timepoints = mice[\"Timepoint\"].apply(models.get_timepoint_value_from_timepoint)\n",
    "    timepoint_units = mice[\"Timepoint\"].apply(models.get_timepoint_units_from_timepoint)\n",
    "    mice[\"Timepoint\"] = timepoints\n",
    "    mice[\"Timepoint unit\"] = timepoint_units\n",
    "    mice = mice[pandas.notnull(mice[\"Timepoint\"])]\n",
    "    \n",
    "    for i, row in mice.iterrows():\n",
    "        dissection_prefix = \"{:03}\".format(row[\"Dissection ID\"])\n",
    "        if not row[\"Mouse Name\"].startswith(dissection_prefix):\n",
    "            raise ValueError(f\"mouse name {row['Mouse Name']} does not start with {dissection_prefix}\")\n",
    "\n",
    "        \n",
    "    return mice\n",
    "\n",
    "mice = load_spreadsheet_mice()\n",
    "mice"
   ]
  },
