    "def convert_ctime(value):\n",
    "    if value is None or len(value) == 0:\n",
    "        return\n",
    "    elif len(value) == 10:\n",
    "        return datetime.datetime.strptime(value, \"%Y-%m-%d\")\n",
    "    else:\n",
    "        return datetime.datetime.strptime(value, \"%Y-%m-%d %H:%M:%S.%f\")\n",
    "\n",
    "\n",
    "def load_fastq_tsv(filename, hostname=None, exists=None):\n",
    "    fastqs = pandas.read_csv(\n",
    "        filename, sep=\"\\t\",\n",
    "        dtype={\n",
    "            \"sequencer_run\": str,\n",
    "            \"plate_id\": str,\n",
    "        },\n",
    "        converters={\n",
    "            \"lane\": str_or_none,\n",
    "            \"fragment\": str_or_none,\n",
    "            \"protocol\": str_or_none,\n",
    "            \"barcode_id\": str_or_none,\n",
    "            \"barcode\": str_or_none,\n",
    "            \"size\": str_or_none,\n",
    "            \"ctime\": convert_ctime,\n",
    "            \"exome_capture\": str_or_none,\n",
    "       }\n",
    "    ).sort_values([\"experiment\", \"subpool_name\", \"barcode_id\", \"lane\", \"read\"])\n",
    "    #fastqs.drop(\"protocol\", axis=1, inplace=True)\n",
    "    if hostname is not None:\n",
    "        fastqs[\"hostname\"] = hostname\n",
    "\n",
    "    if exists is not None:\n",
    "        print(\"Before exists=={} filter. {}\".format(exists, fastqs.shape))\n",
    "        fastqs = fastqs[fastqs[\"exists\"] == exists]\n",
    "        print(\"After exists filter\", fastqs.shape)    \n",
    "\n",
    "    return fastqs\n",
    "\n",
    "fastqs_arughan = load_fastq_tsv(\"fastq_metadata_arughan.tsv\", \"arughan\", exists=True)\n",
    "fastqs_igvf = load_fastq_tsv(\"fastq_metadata_igvf.tsv\", \"igvf\", exists=True)\n",
    "fastqs = pandas.concat([fastqs_arughan, fastqs_igvf])\n",
    "fastqs.shape"
   ]
